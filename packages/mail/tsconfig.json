{
    "extends": "@intune/typescript-config/nestjs.json",
    "compilerOptions": {
        "rootDir": ".",
        "tsBuildInfoFile": ".tsbuildinfo",
        "ignoreDeprecations": "6.0",
        "types": ["node", "jest"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["index.ts", "src/**/*"],
    "exclude": ["node_modules", "dist"]
}
